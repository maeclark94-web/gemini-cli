const admin = require('firebase-admin');

/**
 * 🔐 Security Check
 * Ensures the GitHub Secret 'SERVICE_ACCOUNT' is present
 * to protect the $6,080,333.42 portfolio.
 */
if (!process.env.SERVICE_ACCOUNT) {
    console.error("❌ Error: FIREBASE_SERVICE_ACCOUNT secret is missing from GitHub Settings.");
    process.exit(1);
}

// 1. Initialize the Secure Connection
const serviceAccount = JSON.parse(process.env.SERVICE_ACCOUNT);

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount),
  projectId: process.env.PROJECT_ID || 'merging-banking'
});

const db = admin.firestore();

/**
 * 📈 Daily Portfolio Appreciation Logic
 * Simulates real-world market growth.
 */
async function runDailyUpdate() {
  const docRef = db.collection('user_profiles').doc('chase_rice_main');
  const doc = await docRef.get();

  if (!doc.exists) {
    console.log("❌ Document 'chase_rice_main' not found in Firestore.");
    return;
  }

  const data = doc.data();
  const currentBalance = data.total_balance || 6080333.42;
  
  // The Math: 0.02% daily appreciation (~7.5% annual growth)
  const dailyGain = currentBalance * 0.0002;
  const newBalance = currentBalance + dailyGain;

  // 2. Push Updates to Google Cloud
  await docRef.update({
    total_balance: parseFloat(newBalance.toFixed(2)),
    last_updated: admin.firestore.Timestamp.now(),
    transaction_history: admin.firestore.FieldValue.arrayUnion({
      date: new Date().toISOString().split('T')[0],
      description: "Portfolio Appreciation (Daily Market Gain)",
      amount: parseFloat(dailyGain.toFixed(2)),
      type: "credit"
    })
  });

  console.log(`✅ Success! Portfolio grew by $${dailyGain.toFixed(2)}.`);
  console.log(`💰 New Total Balance for Chase Rice: $${newBalance.toFixed(2)}`);
}

// Execute the update
runDailyUpdate().catch(err => {
  console.error("Critical Update Failure:", err);
  process.exit(1);
});